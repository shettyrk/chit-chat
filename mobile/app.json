{
  "expo": {
    "name": "Chit Chat",
    "slug": "chit-chat",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.natsspringchat",
      "infoPlist": {
        "NSContactsUsageDescription": "Chit Chat uses your contacts to find people who already use the app."
      }
    },
    "android": {
      "package": "com.example.natsspringchat",
      "permissions": [
        "READ_CONTACTS"
      ]
    },
    "plugins": [
      "expo-asset",
      "expo-contacts",
      "expo-font"
    ]
  }
}
