{
  "info": {
    "name": "NATS Spring WhatsApp",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080"},
    {"key": "token", "value": ""}
  ],
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/api/users/register",
        "body": {"mode": "raw", "raw": "{\"name\":\"Alice\",\"phone\":\"1111111111\",\"password\":\"password\"}"}
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/api/users/login",
        "body": {"mode": "raw", "raw": "{\"phone\":\"1111111111\",\"password\":\"password\"}"}
      }
    },
    {
      "name": "Create Chat",
      "request": {
        "method": "POST",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/api/chats",
        "body": {"mode": "raw", "raw": "{\"type\":\"PRIVATE\",\"memberIds\":[1,2]}"}
      }
    },
    {
      "name": "Send Message",
      "request": {
        "method": "POST",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/api/messages",
        "body": {"mode": "raw", "raw": "{\"chatId\":1,\"senderId\":1,\"recipientIds\":[2],\"content\":\"hello\",\"type\":\"TEXT\"}"}
      }
    }
  ]
}
